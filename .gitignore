# Photos and generated output (large / private)
photos_raw/**/*
!photos_raw/**/.gitkeep
photos_processed/**/*
!photos_processed/.gitkeep
build/**/*
!build/.gitkeep

# Per-version generated output (regenerable)
versions/*/build/**/*
!versions/*/build/.gitkeep

# Per-version swap photos ARE tracked (hand-picked replacements)
!versions/*/photos/**
!versions/*/photos/**/*

# Python
.venv/
__pycache__/
*.pyc

# Playwright browsers cache (if local)
.cache/
.playwright/

# OS
.DS_Store
